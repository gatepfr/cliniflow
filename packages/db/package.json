    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "3.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "^8.21.0",
    "prisma": "7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "typescript": "^5",
    "vitest": "4.1.7"
  }
}
