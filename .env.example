# ============================================================
# ClínicaFlow — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=clinica
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://clinica:changeme@localhost:5432/clinicaflow

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- JWT ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-this-secret-in-production-min-32-chars
JWT_REFRESH_SECRET=change-this-other-secret-in-production-min-32-chars
JWT_ACCESS_TTL=15m

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=changeme-dev-key
# EVOLUTION_INSTANCE_NAME is set per tenant at runtime — not a global env var

# --- Sentry (leave empty in development) ---
SENTRY_DSN=

# --- App ---
NODE_ENV=development
LOG_LEVEL=info
PORT=3000
